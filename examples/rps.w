@s Rat int
@s Int int
@s testing.T int

@* 커피 내기. ``우리 가위바위보로 커피 내기 하자! 꼴지 한 명이 쏘는 걸로!''
어디선가 솔깃한 제안이 들려온다. 한여름 나른한 오후, 점심 식사 후 그렇지 않아도
커피가 땡기던 참이었다. 다들 같은 마음이었는지 반대하는 이 하나 없이 모두 오케이.
열 명이나 되는 한 무리가 주위의 시선 따위는 아랑곳하지 않고 동시에 ``가위, 바위,
보!''를 외친다. 그런데 열 명이 한꺼번에 내니 좀처럼 꼴지가 가려지지 않는다. 매번
세 손이 골고루 나와 도로 원점이다. 보다 못한 누군가 두 그룹으로 나눠서 하자고
했지만, 업무 복귀까지는 아직 시간이 넉넉했다. 대체 언제 끝나나 하는 오기 반,
호기심 반으로 다들 그냥 하던 대로 밀어붙이기로 했다. 수차례의 헛손질 끝에 드디어
꼴지가 정해졌는데, 다행히 나는 아니다. 오늘따라 커피가 더 맛있겠다. 날이 더우니
아이스로 해야지. 그러다 문득, 아이스 바닐라 라떼처럼 시원하면서도 달콤한 생각
두 가지가 떠올랐다.

\smallskip
\item{$\bullet$} $N$명이 한꺼번에 게임을 벌일 때, 평균 몇 판이나 해야 꼴지가
   가려질까?
\item{$\bullet$} 게임 판수를 최소로 줄이려면, $N$명을 몇 개의 그룹으로 나누어
   진행하는 게 가장 빨리 끝날까?
\smallskip

\noindent 첫 번째 물음은 우리가 왜 그토록 오래 손을 내저었는지 그 억울함을 숫자로
밝혀 줄 것이고, 두 번째 물음은 그 억울함을 다음번엔 어떻게 피할지 일러 줄 것이다.
한글 \.{GWEB}으로 이 두 가지를 차근차근 풀어 보기로 했다. 답은 모두 분수 한 톨
틀리지 않는 {\it 정확한\/} 유리수라, 어림수로 얼버무리지 않으려고 셈은 |math/big|의
임의 정밀도 산술에 맡긴다.

@ 프로그램의 뼈대는 아래와 같다. 앞의 두 별표 절이 첫 번째 물음(한 판이 승부날
확률과 그로부터 얻는 기대 판수 |expected|)에 답하고, 그다음 절이 두 번째 물음(모든
나누기를 |partitions|로 훑어 가장 싼 편성을 |optimize|가 고르기)에 답한다. |pow3|과
|binom|은 점화식에 쓰이는 자잘한 셈을 정확한 정수로 처리하는 도우미다. |main|은
그 둘을 불러 표 두 개를 찍는 게 전부다. 변수 |N|은 표를 사람 수 몇 명까지 그릴지
정한다 --- 그날 무리는 열 명이었으니 기본값은 넉넉히 열둘로 두되, 더 큰 무리가
궁금하면 명령행에서 \.{./rps 30}처럼 숫자 하나를 건네 얼마든지 늘릴 수 있게 했다.

@c
package main

import (
	"fmt"
	"math/big"
	"os"
	"strconv"
	"strings"
)

@<함수들@>@;

func main() {
	N := 12 // 표를 그릴 최대 인원; 기본값이자 명령행 인자가 없을 때의 값
	@<명령행 인자로 인원 상한을 받는다@>
	E := expected(N)
	C, best := optimize(E)
	@<첫 번째 물음의 답을 표로 낸다@>
	@<두 번째 물음의 답을 표로 낸다@>
}

@ 인자가 있으면 첫째 것을 인원 상한으로 삼는다. 숫자로 읽히지 않거나 둘보다 작으면
(둘은 있어야 게임이 성립하니) 잠자코 무시하고 기본값을 지킨다.

@<명령행 인자로 인원 상한을 받는다@>=
if len(os.Args) > 1 {
	if n, err := strconv.Atoi(os.Args[1]); err == nil && n >= 2 {
		N = n
	}
}

@ 두 도우미부터. |pow3|은 $3^e$을, |binom|은 이항계수 $n\choose k$를 임의 정밀도
정수로 돌려준다. 표준 라이브러리의 |big.Int|에 |Exp|와 |Binomial|이 이미 있으니
우리는 이름만 붙여 주면 된다.

@<함수들@>=
func pow3(e int) *big.Int {
	return new(big.Int).Exp(big.NewInt(3), big.NewInt(int64(e)), nil)
}

func binom(n, k int) *big.Int {
	return new(big.Int).Binomial(int64(n), int64(k))
}

@* 한 판이 승부날 확률. 왜 그리 안 끝났는지부터 따져 보자. $k$명이 저마다 가위,
바위, 보 가운데 하나를 무심히 낸다면 한 판의 경우의 수는 $3^k$가지이고 모두 똑같이
그럴듯하다. 이 가운데 {\it 승부가 나는\/}, 곧 비기지 않는 경우는 언제인가? 곰곰이
따져 보면 답은 뜻밖에 깔끔하다: 세 손 가운데 정확히 {\it 두 종류\/}만 나와야 한다.
한 종류만 나오면(모두 바위) 당연히 비기고, 세 종류가 다 나오면 가위는 보를, 보는
바위를, 바위는 가위를 이겨 물고 물리니 역시 승부가 나지 않는다. 물이 불을, 불이 쇠를,
쇠가 나무를, 나무가 흙을, 흙이 다시 물을 이겨 꼬리에 꼬리를 무는 오행(五行)의
상극(相剋) --- 가위바위보가 세 손으로 벌이는 이 순환을, 우리 선조들은
다섯으로 짜 두었다 --- 그 시작도 끝도 없는 돌고 돎과 똑같은 이치다.

@ 그러니 승부가 나는 판을 세는 일은 곧 ``두 종류의 손''을 세는 일이다. 나오는 두
손을 고르는 방법은 $\{$가위,\thinspace 바위$\}$, $\{$바위,\thinspace 보$\}$,
$\{$보,\thinspace 가위$\}$의 세 가지이고, 각 쌍마다 이기고 지는 쪽이 이미 정해져
있다. 고른 두 손만으로 $k$명을 채우되 둘 다 적어도 한 번은 나오는 배정은 $2^k-2$
가지이므로, 승부가 나는 경우의 수는 $3(2^k-2)$. 따라서 한 판에 승부가 날 확률은
$$p_k={3(2^k-2)\over 3^k}={2^k-2\over 3^{\,k-1}}.$$
이 식이 우리의 억울함을 설명한다. 둘이 하면 $p_2={2\over3}$, 셋이 해도 여전히
$p_3={6\over9}={2\over3}$로 후하지만, 열 명이 모이면 $p_{10}={1022\over19683}
\approx0.052$로 곤두박질친다. 스무 판을 내던져야 겨우 한 판 결판이 나는 셈이니,
그 오후의 무한 루프는 우리의 게으름 탓이 아니라 지수함수의 탓이었던 것이다.
|decisiveProb|가 바로 이 $p_k$를, 부동소수점의 반올림 없이 정확한 유리수로
돌려준다.

@<함수들@>=
func decisiveProb(k int) *big.Rat {
	num := new(big.Int).Sub(new(big.Int).Lsh(big.NewInt(1), uint(k)), big.NewInt(2))
	return new(big.Rat).SetFrac(num, pow3(k-1))
}

@* 기대 판수의 점화식. 꼴지를 가리는 규칙을 또렷이 하자. 한 판에서 승부가 나면
{\it 이긴\/} 쪽은 ``나는 꼴지가 아니다''라며 유유히 빠지고, {\it 진\/} 쪽만 남아
저희끼리 다시 겨룬다. 이렇게 지는 무리가 점점 줄다가 마지막 한 명이 남으면 그가
바로 커피를 쏠 꼴지다. $E_k$를 ``$k$명이 남은 판에서 꼴지가 정해질 때까지 치르는
기대 판수''라 두고, 첫 판의 결과에 따라 경우를 나눠 보자.

첫 판이 비기면(확률 $1-p_k$) 아무도 못 빠지고 그대로 $k$명이 다시 시작한다. 승부가
나면 진 쪽 인원 $j$명이 남아 $E_j$의 상태로 넘어가는데, 진 쪽이 하필 $j$명일 확률은
앞 절의 셈에서 ${3{k\choose j}/3^k}$이다$(1\le j\le k-1)$. 그러므로
$$E_k=1+(1-p_k)\,E_k+\sum_{j=1}^{k-1}{{1\over3^{k-1}}{k\choose j}}\,E_j.$$
$E_k$항을 왼쪽으로 모아 정리하면 분모의 $3$이 예쁘게 약분되어
$$E_k={1\over2^k-2}\bigg\{3^{\,k-1}+\sum_{j=1}^{k-1}{k\choose j}\,E_j\bigg\},\quad E_1=0$$
이라는 점화식이 남는다. 작은 것부터 큰 것으로 한 번에 채워 넣으면 그만이다.
|expected|는 이렇게 $E_0$부터 $E_n$까지를 한 슬라이스에 담아 돌려준다. |E[k]|가
$k$명이 함께 시작해 꼴지 한 명이 남을 때까지의 기대 판수다.

@<함수들@>=
func expected(n int) []*big.Rat {
	E := make([]*big.Rat, n+1)
	E[0], E[1] = new(big.Rat), new(big.Rat)
	for k := 2; k <= n; k++ {
		num := new(big.Rat).SetInt(pow3(k - 1))
		for j := 1; j < k; j++ {
			t := new(big.Rat).Mul(new(big.Rat).SetInt(binom(k, j)), E[j])
			num.Add(num, t)
		}
		den := new(big.Int).Sub(new(big.Int).Lsh(big.NewInt(1), uint(k)), big.NewInt(2))
		E[k] = new(big.Rat).Quo(num, new(big.Rat).SetInt(den))
	}
	return E
}

@ 이제 첫 번째 물음의 답을 표로 뽑는다. 돌려 보면 $E_{10}={8327737507\over
342007190}\approx24.35$. 열 명이 꼴지 하나 가리자고 평균 스물너덧 판을 내지른다는
뜻이다. 커피 한 잔 정하는 데 그만한 품이 드니 그날 우리가 지쳐 나가떨어질 만도
했다. 여기서 만든 |E|는 바로 다음 물음에서도 그대로 쓴다.

@<첫 번째 물음의 답을 표로 낸다@>=
fmt.Println("사람수   한 판 승부 확률      기대 판수")
for k := 2; k <= N; k++ {
	fmt.Printf("%4d명   %14s   %8s  (= %s)\n",
		k, decisiveProb(k).FloatString(4), E[k].FloatString(3), E[k].RatString())
}

@* 나누어 정복하기. 그러면 두 번째 물음. 판수를 줄이려면 무리를 어떻게 쪼개야
할까? 착상은 단순하다. $k$명을 몇 개의 그룹으로 나눠 그룹마다 저희 꼴지를 하나씩
가려낸 다음, 그 그룹 꼴지들끼리 마지막 승부를 벌여 {\it 꼴지 중의 꼴지\/}를 뽑으면
된다. 전체의 진짜 꼴지는 반드시 제 그룹에서도 꼴지였을 터이니 이렇게 뽑아도
공정하다. 치른 판수는 각 그룹에서의 판과 결승에서의 판을 모두 더한 값이다.

$k$명의 꼴지를 가리는 데 드는 최소 기대 판수를 $C(k)$라 하자. 그냥 다 함께 하면
$E_k$판이 든다. 아니면 $k=m_1+\cdots+m_g$로 나눠 각 그룹을 (또다시 최선으로) 풀고
결승을 치르는데, 그 비용은 $\sum_i C(m_i)+C(g)$이다. 둘 중 싼 쪽을 고르므로
$$C(k)=\min\Bigl(E_k,\ \min_{k=m_1+\cdots+m_g}\bigl[\,\textstyle\sum_i
   C(m_i)+C(g)\,\bigr]\Bigr).$$
공정하려면 그룹 하나에 적어도 두 명은 있어야 하니 나누는 조각은 $2$ 이상으로 둔다.
작은 $k$부터 $C(k)$를 채워 두면 큰 $k$를 풀 때 곧바로 꺼내 쓸 수 있다.

@ 나누는 모든 방법을 훑으려면 정수 $n$을 |minPart| 이상의 조각으로 쪼개는
{\it 분할\/}을 남김없이 만들어야 한다. |partitions|는 그렇게 만든 편성을 하나씩
|yield|에 넘기는데, |cur|에 지금까지 고른 조각을 쌓아 가며 조각을 오름차순으로만
이어 붙여 같은 편성을 두 번 세지 않는, 교과서적인 재귀다.

@<함수들@>=
func partitions(n, minPart int, cur []int, yield func([]int)) {
	if n == 0 {
		yield(cur)
		return
	}
	for p := minPart; p <= n; p++ {
		partitions(n-p, p, append(cur, p), yield)
	}
}

@ |optimize|는 위 점화식을 그대로 옮겨, |E[]|를 받아 인원수마다 최소 기대 판수
|C[]|와 그때의 최선의 편성 |best[]|를 함께 돌려준다. 먼저 모든 |C[k]|를 ``그냥
함께 하는'' 비용 $E_k$로 깔아 두고, $k=4$부터(그보다 작으면 나눌 여지가 없다) 더
싼 편성이 있으면 갈아 끼운다. 이긴 편성은 |best[k]|에 적어 두는데, 끝내 |nil|로
남았다면 그냥 다 함께 하는 편이 최선이라는 뜻이다.

@<함수들@>=
func optimize(E []*big.Rat) (C []*big.Rat, best [][]int) {
	n := len(E) - 1
	C = make([]*big.Rat, n+1)
	best = make([][]int, n+1)
	for k := 0; k <= n; k++ {
		C[k] = new(big.Rat).Set(E[k])
	}
	for k := 4; k <= n; k++ {
		partitions(k, 2, nil, func(p []int) {
			@<편성 |p|가 더 싸면 |C[k]|를 갈아 끼운다@>
		})
	}
	return C, best
}

@ 한 편성 |p|의 비용은 조각마다의 |C[m]|을 더하고, 그룹 꼴지들의 결승 비용
|C[len(p)]|을 마저 얹은 값이다. 조각이 하나뿐인 편성(|len(p) < 2|)은 나눈 것이
아니므로 건너뛴다.

@<편성 |p|가 더 싸면 |C[k]|를 갈아 끼운다@>=
if len(p) < 2 {
	return
}
cost := new(big.Rat)
for _, m := range p {
	cost.Add(cost, C[m])
}
cost.Add(cost, C[len(p)])
if cost.Cmp(C[k]) < 0 {
	C[k].Set(cost)
	best[k] = append([]int(nil), p...)
}

@ 표를 보면 답이 스스로 모습을 드러낸다. 최선의 편성에는 언제나 {\it 3명과 4명\/}
그룹만 나온다 --- 2명씩은 그룹은 많아지는데 결승 부담만 키워 손해고, 5명 이상은
앞서 본 대로 좀처럼 승부가 안 나 손해다. 그 사이 어딘가, 딱 서넛이 황금의 자리다.
우리의 열 명은 $(3,3,4)$의 {\it 세 그룹\/}으로 나누는 것이 최선이라, 기대 판수가
$24.35$에서 ${279\over28}\approx9.96$으로 뚝 떨어진다. 거의 두 배 반이나 빠르다.
그날 두 그룹으로 나누자던 누군가의 직감은 옳았고, 다만 한 끗이 모자랐다. 세
그룹이었다면 우리는 훨씬 이른 커피를 마셨으리라.

@<두 번째 물음의 답을 표로 낸다@>=
fmt.Println("\n사람수   함께(판수)   나눠서(판수)   최선의 편성")
for k := 2; k <= N; k++ {
	plan := "그냥 함께"
	if best[k] != nil {
		@<편성 |best[k]|를 재귀 노드까지 드러내 |plan|으로 짓는다@>
	}
	fmt.Printf("%4d명   %9s   %9s   %s\n",
		k, E[k].FloatString(2), C[k].FloatString(2), plan)
}

@ 여기 한 가지 함정이 있다. |best[k]|에는 편성의 {\it 맨 위 한 층\/}만 적혀 있고,
각 조각의 비용으로는 |E[m]|이 아니라 |C[m]|을, 곧 그 인원을 다시 최적으로 쪼갠 값을
썼음을 떠올리자. 그래서 열두 명을 넘어서면 |best[28]=[4 4 4 16]|처럼 큼직한 수가
불쑥 끼어드는데, 이 ``16''은 열여섯이 한 판에 뭉쳐 논다는 뜻이 결코 아니다 --- 그저
``열여섯은 다시 재귀하라''는 이정표일 뿐이라, 펼쳐 보면 |[4 4 4 4]|로 또 넷씩 갈린다
(그러니 실제로 손을 내미는 그룹은 여전히 온통 서넛짜리다). 이 속내가 표에서도
드러나도록, 조각 |m|이 제 나름 더 쪼개지는 놈이면(|best[m]| 이 |nil|이 아니면)
대괄호로 한 겹 더 감싸 |[16]|처럼 적어, 진짜 그룹과 재귀 노드를 눈으로 갈라 준다.

@<편성 |best[k]|를 재귀 노드까지 드러내 |plan|으로 짓는다@>=
var b strings.Builder
b.WriteByte('[')
for i, m := range best[k] {
	if i > 0 {
		b.WriteByte(' ')
	}
	if best[m] != nil {
		fmt.Fprintf(&b, "[%d]", m)
	} else {
		fmt.Fprintf(&b, "%d", m)
	}
}
b.WriteByte(']')
plan = b.String()

@ 마침내 프로그램을 돌려 두 물음의 답을 한 상에 차려 본다. 위쪽 표가 첫 번째 물음
(함께 할 때의 기대 판수)에, 아래쪽 표가 두 번째 물음(어떻게 나눌지)에 대한
답이다. 열 명 줄을 보라: 함께 하면 $24.35$판이지만 $(3,3,4)$로 나누면 $9.96$판이다.

\verbatim
사람수   한 판 승부 확률      기대 판수
   2명           0.6667      1.500  (= 3/2)
   3명           0.6667      2.250  (= 9/4)
   4명           0.5185      3.214  (= 45/14)
   5명           0.3704      4.486  (= 157/35)
   6명           0.2551      6.220  (= 13497/2170)
   7명           0.1728      8.647  (= 225161/26040)
   8명           0.1161     12.104  (= 10007591/826770)
   9명           0.0777     17.092  (= 200190574/11712575)
  10명           0.0519     24.350  (= 8327737507/342007190)
  11명           0.0346     34.979  (= 52638199503/1504831636)
  12명           0.0231     50.625  (= 389862062796301/7700975897230)
\smallskip
사람수   함께(판수)   나눠서(판수)   최선의 편성
   2명        1.50        1.50   그냥 함께
   3명        2.25        2.25   그냥 함께
   4명        3.21        3.21   그냥 함께
   5명        4.49        4.49   그냥 함께
   6명        6.22        6.00   [3 3]
   7명        8.65        6.96   [3 4]
   8명       12.10        7.93   [4 4]
   9명       17.09        9.00   [3 3 3]
  10명       24.35        9.96   [3 3 4]
  11명       34.98       10.93   [3 4 4]
  12명       50.63       11.89   [4 4 4]
\endverbatim

\noindent 그러고 보니 이 결론은 여느 삶의 지혜와 닮았다. 혼자 다 떠안으면(큰 한
그룹) 일은 끝날 줄 모르고, 잘게 쪼개 너무 많은 이에게 미루면(둘씩) 뒤처리가 되레
늘어난다. 서넛이 오붓하게 나눠 맡을 때 일이 가장 빨리 끝난다 --- 가위바위보조차
그렇게 말하고 있었다. 이제 다음 여름, 그 솔깃한 제안이 또 들어오거든 나는 슬며시
이렇게 말할 참이다. ``세 그룹으로 나눠서 하죠.''

@* 백 명이 모이면. 열 명으로도 진이 빠졌는데, 회사 전체 백 명이 같은 내기를
벌인다면 어떨까? 다 함께 손을 내젓는다면 --- 한 판이 승부날 확률 $p_{100}$이 이미
$10^{-16}$ 언저리라 --- 꼴지를 가리기까지 평균 $1.35\times10^{17}$판이 필요하다.
우주의 나이가 $10^{17}$초 남짓이니, 첫 빅뱅과 함께 게임을 시작해 매초 한 판씩
쉼 없이 던져 왔다 해도 우리는 아직 꼴지를 못 가렸을 것이다.

살길은 하나, 나누는 것이다. 그것도 한 번이 아니라 끝날 때까지. 작은 그룹으로 갈라
각자 꼴지를 뽑고, 그 꼴지들만 다시 그러모아 또 작은 그룹으로 갈라 뽑고 --- 한 명이
남을 때까지 이 ``꼴지들의 토너먼트''를 되풀이한다. 백 명은 그렇게 대략
$$100\to25\to6\to2\to1$$
넉 단계 만에 스러진다. 앞서 열 명을 $(3,3,4)$로 나눈 뒤 꼴지 셋으로 결승을 벌인
것과 똑같은 짜임인데, 다만 결승이 또 한 번의 나누기가 되어 재귀로 깊어질 뿐이다.

@ 사실 진짜 최적을 구하려면 모든 편성을 뒤져야 하지만, 백을 $2$ 이상으로 쪼개는
분할만도 $1.9\times10^8$가지라 앞의 |optimize|로는 엄두가 안 난다 --- 한 다스를
넘기자 완전 탐색마저 저 나름의 지수 폭발에 걸리는 셈이다. 다행히 꼭 최적을 캘
것도 없다. ``그저 작은 크기로 자르고 또 자른다''는 단순한 규칙 하나면 최적에
털끝만큼 못 미치는 곳까지 곧장 닿는다. |recCost|가 그 규칙의 값을 잰다: $k$명을
되도록 |size|명씩 나눠 각 그룹은 함께 풀고(그래서 $E$가 든다), 나온 꼴지 $g$명을
같은 규칙으로 재귀한다.

@<함수들@>=
func recCost(E []*big.Rat, k, size int) *big.Rat {
	if k <= size {
		return E[k]
	}
	g := (k + size/2) / size // |k/size|를 반올림한 그룹 수
	if g < 2 {
		g = 2
	}
	base, rem := k/g, k%g // |rem|개 그룹은 |base+1|명, 나머지는 |base|명
	total := new(big.Rat)
	for i := 0; i < g; i++ {
		m := base
		if i < rem {
			m = base + 1
		}
		total.Add(total, E[m])
	}
	total.Add(total, recCost(E, g, size))
	return total
}

@ 백 명까지 $E$를 마련해 두고, 다 함께 할 때의 아득한 판수와 $2\cdot3\cdot4$명씩
나눠 재귀할 때의 판수를 나란히 재 본다. 이 셈은 커피 내기의 답을 내는 데 꼭 필요한
것은 아니라, 프로그램의 출력이 아니라 뒤 「시험」 절의 |TestRecCost|에 딸려 두었다.
\.{go test}로 돌려 보면 이렇게 찍힌다.

\verbatim
백 명이 다 함께: 평균 1.355e+17 판
2명씩 나눠 재귀: 148.50 판
3명씩 나눠 재귀: 112.71 판
4명씩 나눠 재귀: 106.91 판
\endverbatim

\noindent $10^{17}$이 $10^2$으로 주저앉았다. 나누기의 위력은 규모가 클수록 더
아찔하다. 그런데 눈여겨볼 대목이 하나 있다: 이번엔 {\it 4명씩\/}이 3명씩을
앞선다(참고로 |recCost|로 열 명을 3명씩 재 보면 정확히 $9.96$판, 앞의 최적표와 한
치도 어긋나지 않는다). 그렇다면 한 그룹에 몇 명을 넣는 것이 이상적일까? 이건
어림짐작할 게 아니라 증명할 수 있다.

@* 왜 하필 넷인가. 앞서 열 명의 답을 ``세 그룹''이라 했는데, 그 {\it 셋\/}은
그룹의 {\it 개수\/}($g=3$, 편성 $(3,3,4)$)였지 한 그룹의 {\it 인원\/}이 아니었다.
이제 물음을 뒤집어, 그룹마다 {\it 몇 명씩\/} 넣어야 가장 빠른지를 따지자. 규모가
크면 편성이 거의 균일해지므로, ``모든 그룹을 크기 $m$으로''라는 이상화 아래 총
판수를 세어 본다.

$N$명이 크기 $m$ 그룹으로 나뉘면 $N/m$개 그룹이 각각 $E_m$판을 치르고, 살아남는
꼴지는 $N/m$명. 이들이 다시 같은 규칙으로 줄어드니, 총 판수는 등비급수로 모인다:
$$\hbox{총 판수}=E_m\Bigl({N\over m}+{N\over m^2}+{N\over m^3}+\cdots\Bigr)
   =E_m\cdot{N/m\over 1-1/m}=N\cdot{E_m\over m-1}.$$
$N$은 공통 인수로 빠지므로, 이상적 크기는 {\it 규모와 무관하게\/} 한 사람 몫의 비용
$$f(m)={E_m\over m-1}$$
을 가장 작게 만드는 $m$ 하나로 정해진다. 남은 일은 이 $f(m)$을 재는 것뿐이다.

@<함수들@>=
func groupEfficiency(E []*big.Rat, m int) *big.Rat {
	return new(big.Rat).Quo(E[m], big.NewRat(int64(m-1), 1))
}

@ $m=2$부터 훑으며 $f(m)$을 재고 가장 작은 $m$을 짚는 일 역시 뒤 「시험」 절의
|TestGroupEfficiency|에 맡겼다. \.{go test}로 돌려 보면 이렇게 나온다.

\verbatim
그룹 크기 m의 효율 f(m)=E_m/(m-1) (작을수록 좋음):
  m=2: 1.5000
  m=3: 1.1250
  m=4: 1.0714
  m=5: 1.1214
  m=6: 1.2440
  m=7: 1.4411
→ 최적 그룹 크기 = 4명 (f=1.0714)
\endverbatim

\noindent $f(m)$은 정확한 분수로 $f(2)={3\over2}$, $f(3)={9\over8}$, $f(4)={15\over14}$,
$f(5)={157\over140}$이며, 최소는 $m=4$다. 손으로도 못 박을 수 있다: $f(4)<f(3)$은
${15\over14}<{9\over8}\iff 15\cdot8<9\cdot14\iff 120<126$이라 참이고, $f(4)<f(5)$는
${150\over140}<{157\over140}$이라 참이다. $m=2$는 결승이 너무 잦아 손해, $m\ge6$은
승부가 잘 안 나 손해 --- 그 사이 골짜기의 바닥이 정확히 {\bf 넷}이다(셋과 다섯이 근소한
차이로 양옆에 선다). 그러니 규모가 어떻든 답은 하나다: {\it 네 명씩 갈라 꼴지만
남기기를 되풀이하라.\/} 작은 무리에서 셋이 이기곤 하는 것은 마지막 몇 판의 자투리
효과일 뿐, 골짜기의 바닥은 언제나 넷이다. 백 명이든 천 명이든, 커피는
$N\cdot{15\over14}$판, 곧 사람 수보다 조금 많은 판이면 정해진다.

@* 시험. 유도한 식이 정말 맞는지, 부수 파일 \.{rps\_test.go}에 몇 가지 시험을
붙여 둔다. 손으로도 확인할 수 있는 작은 값들과, 도저히 손으로는 엄두가 안 나는 큰
값들을 함께 넣어 두 방향에서 옭아맨다. 시험마다 기댓값을 ``분자/분모'' 꼴 문자열로
적어 두는데, 그것을 정확한 유리수로 되읽어 주는 도우미 |rat|을 먼저 마련한다.
\.{go test}로 돌린다.

@(rps_test.go@>=
package main

import (
	"fmt"
	"math/big"
	"reflect"
	"testing"
)

func rat(s string) *big.Rat {
	r, ok := new(big.Rat).SetString(s)
	if !ok {
		panic("bad rat: " + s)
	}
	return r
}

@ 한 판 승부 확률 $p_k$는 손으로도 검산이 된다: $p_2=p_3={2\over3}$, 열 명이면
$p_{10}={1022\over19683}$, 스무 명이면 $p_{20}={1048574\over1162261467}\approx
0.0009$ --- 천 판에 한 번꼴로만 결판이 난다는 뜻이니, 스무 명이 함께 하기란 사실상
가망이 없는 셈이다.

@(rps_test.go@>=
func TestDecisiveProb(t *testing.T) {
	cases := map[int]string{2: "2/3", 3: "2/3", 10: "1022/19683", 20: "1048574/1162261467"}
	for k, want := range cases {
		if got := decisiveProb(k); got.Cmp(rat(want)) != 0 {
			t.Errorf("decisiveProb(%d) = %s, want %s", k, got.RatString(), want)
		}
	}
}

@ 기대 판수 $E_k$도 작은 값은 눈으로 확인된다($E_2={3\over2}$, $E_3={9\over4}$).
큰 값이야말로 임의 정밀도 산술의 진가가 드러나는 자리다: 스무 명이 함께 하면
평균 판수가 무려 $E_{20}\approx1143$판에 이른다. 정말로 하루가 다 가도 못 끝낼
노릇이다.

@(rps_test.go@>=
func TestExpected(t *testing.T) {
	E := expected(20)
	cases := map[int]string{
		1:  "0",
		2:  "3/2",
		3:  "9/4",
		10: "8327737507/342007190",
		20: "8576155080550131610959831097970895507929"+
        "/"+
        "7503833033267727220482012085501624614",
	}
	for k, want := range cases {
		if E[k].Cmp(rat(want)) != 0 {
			t.Errorf("E[%d] = %s, want %s", k, E[k].RatString(), want)
		}
	}
}

@ 마지막으로 나누기 전략. 최선의 비용과 편성이 손으로 미리 구해 둔 값과 맞는지
본다: 열 명은 $(3,3,4)$로 ${279\over28}$판, 열다섯 명은 $(3,4,4,4)$로 ${423\over28}$
판, 스무 명은 {\it 4명씩 다섯 그룹\/} $(4,4,4,4,4)$로 ${1439\over70}\approx20.6$판
이다. 스무 명이 함께 하면 천 판이 넘는데 나누면 스물한 판 남짓이니, 나누기의
위력이 그야말로 극적이다. 편성표가 온통 3과 4로만 채워지는 것도 다시 확인한다.

@(rps_test.go@>=
func TestOptimize(t *testing.T) {
	E := expected(20)
	C, best := optimize(E)
	costs := map[int]string{10: "279/28", 15: "423/28", 20: "1439/70"}
	for k, want := range costs {
		if C[k].Cmp(rat(want)) != 0 {
			t.Errorf("C[%d] = %s, want %s", k, C[k].RatString(), want)
		}
	}
	plans := map[int][]int{10: {3, 3, 4}, 15: {3, 4, 4, 4}, 20: {4, 4, 4, 4, 4}}
	for k, want := range plans {
		if !reflect.DeepEqual(best[k], want) {
			t.Errorf("best[%d] = %v, want %v", k, best[k], want)
		}
	}
	if C[20].Cmp(E[20]) >= 0 {
		t.Errorf("나누기가 이득이 아니다: C=%s E=%s", C[20].FloatString(2), E[20].FloatString(2))
	}
}

@ |partitions| 자체도 옭아맨다. 만들어 낸 조각의 합이 언제나 $n$인지, 그리고
$n$을 2 이상 조각으로 나누는 분할의 개수가 알려진 수열(OEIS \.{A002865}:
$1,1,2,2,4,4,7,8,12,\ldots$)과 맞는지 센다.

@(rps_test.go@>=
func TestPartitionsCount(t *testing.T) {
	want := []int{0, 0, 1, 1, 2, 2, 4, 4, 7, 8, 12} // |want[n] = n|의 분할 수 (|part>=2|)
	for n := 2; n <= 10; n++ {
		count := 0
		partitions(n, 2, nil, func(p []int) {
			sum := 0
			for _, x := range p {
				sum += x
			}
			if sum != n {
				t.Fatalf("분할 %v의 합이 %d != %d", p, sum, n)
			}
			count++
		})
		if count != want[n] {
			t.Errorf("partitions(%d) 개수 = %d, want %d", n, count, want[n])
		}
	}
}

@ 끝으로 재귀 전략. 앞서 「백 명이 모이면」 절에 실은 표를 실제로 찍어 내는 것이
바로 이 시험이다. 그러면서 두 가지를 못 박는다: 열 명을 3명씩 재귀하면 완전 탐색이
찾은 최적 ${279\over28}$과 한 치도 다르지 않다는 교차검증, 그리고 백 명은 나누는
편이 다 함께 하는 것보다 압도적으로 싸다는 자명하지만 통쾌한 사실.

@(rps_test.go@>=
func TestRecCost(t *testing.T) {
	E := expected(100)
	together, _ := E[100].Float64()
	fmt.Printf("\n백 명이 다 함께: 평균 %.3e 판\n", together)
	for _, size := range []int{2, 3, 4} {
		fmt.Printf("%d명씩 나눠 재귀: %s 판\n", size, recCost(E, 100, size).FloatString(2))
	}
	if got := recCost(E, 10, 3); got.Cmp(rat("279/28")) != 0 {
		t.Errorf("recCost(10,3) = %s, want 279/28", got.RatString())
	}
	if recCost(E, 100, 4).Cmp(E[100]) >= 0 {
		t.Errorf("나누기가 다 함께보다 싸지 않다")
	}
}

@ 그리고 한 그룹의 최적 크기가 넷이라는 증명의 알맹이. 「왜 하필 넷인가」 절의
$f(m)$ 표를 찍어 내면서, $f(4)={15\over14}$가 $2\le m\le7$의 어떤 $f(m)$보다도 작아
골짜기의 바닥이 정확히 넷임을 확인한다.

@(rps_test.go@>=
func TestGroupEfficiency(t *testing.T) {
	E := expected(8)
	fmt.Println("\n그룹 크기 m의 효율 f(m)=E_m/(m-1) (작을수록 좋음):")
	bestm := 0
	var bestf *big.Rat
	for m := 2; m <= 7; m++ {
		f := groupEfficiency(E, m)
		if bestf == nil || f.Cmp(bestf) < 0 {
			bestm, bestf = m, f
		}
		fmt.Printf("  m=%d: %s\n", m, f.FloatString(4))
	}
	fmt.Printf("→ 최적 그룹 크기 = %d명 (f=%s)\n", bestm, bestf.FloatString(4))
	if bestm != 4 {
		t.Errorf("최적 크기가 4가 아니라 %d로 나온다", bestm)
	}
	if got := groupEfficiency(E, 4); got.Cmp(rat("15/14")) != 0 {
		t.Errorf("f(4) = %s, want 15/14", got.RatString())
	}
}

