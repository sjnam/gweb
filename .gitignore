# build outputs
/bin/
/.bootstrap/
/build/

# Go tangled from the .w sources that is NOT committed: following cweb's tradition, only
# the Go needed to build gtangle the first time is kept in the repo (common/
# and cmd/gtangle/gtangle.go); all of gweave and every test are generated by
# `make generate`.
/cmd/gtangle/gtangle_test.go
/cmd/gweave/gweave.go
/cmd/gweave/gweave_test.go
/common/common_test.go

# tangled / woven artifacts
*.go.tmp
examples/*.go
examples/*.tex
examples/*.dvi
examples/*.pdf
examples/*.ps
examples/*.log
examples/*.toc
examples/*.idx
examples/*.scn

# but keep sources
!examples/*.w

# woven output left in a component's own directory when it is woven standalone
# (each of the three component webs carries its own \title and \topofcontents)
/common/*.tex
/common/*.pdf
/common/*.dvi
/common/*.log
/common/*.ps
/cmd/gtangle/*.tex
/cmd/gtangle/*.pdf
/cmd/gtangle/*.dvi
/cmd/gtangle/*.log
/cmd/gtangle/*.ps
/cmd/gweave/*.tex
/cmd/gweave/*.pdf
/cmd/gweave/*.dvi
/cmd/gweave/*.log
/cmd/gweave/*.ps

# rasterized previews
*.png

# stray TeX scratch logs, and CWEB cweave aux files (.idx index, .scn section
# names) -- gweave never writes these, but running cweave in-tree drops them
texput.log
*.toc
*.idx
*.scn

# VS Code extension package
*.vsix

.markdownlint.jsonc

