# build outputs
/bin/
/.bootstrap/
/build/

# Go tangled from lit/*.w that is NOT committed: following cweb's tradition, only
# the Go needed to build gtangle the first time is kept in the repo (internal/web
# and cmd/gtangle's main.go + tangle.go); all of gweave and every test are
# generated by `make generate`.
/cmd/gtangle/tangle_test.go
/cmd/gtangle/build_test.go
/cmd/gweave/main.go
/cmd/gweave/weave.go
/cmd/gweave/tex.go
/cmd/gweave/gotok.go
/cmd/gweave/xref.go
/cmd/gweave/weave_test.go
/internal/web/web_test.go

# tangled / woven artifacts
*.go.tmp
examples/*.go
examples/*.tex
examples/*.dvi
examples/*.pdf
examples/*.ps
examples/*.log
examples/*.toc
examples/*.idx
examples/*.scn

# but keep sources
!examples/*.w

# rasterized previews
*.png

# stray TeX scratch logs, and CWEB cweave aux files (.idx index, .scn section
# names) -- gweave never writes these, but running cweave in-tree drops them
texput.log
*.toc
*.idx
*.scn

# VS Code extension package
*.vsix
