# build outputs
/bin/
/.bootstrap/
/build/

# Go tangled from lit/*.w that is NOT committed: following cweb's tradition, only
# the Go needed to build gtangle the first time is kept in the repo; gweave, the
# weave package, and the test files (which live in the .w sources) are generated
# by `make generate`.
/cmd/gweave/main.go
/internal/weave/weave.go
/internal/weave/tex.go
/internal/weave/gotok.go
/internal/weave/xref.go
/internal/web/web_test.go
/internal/tangle/tangle_test.go
/internal/tangle/build_test.go
/internal/weave/weave_test.go

# tangled / woven artifacts
*.go.tmp
examples/*.go
examples/*.tex
examples/*.dvi
examples/*.pdf
examples/*.ps
examples/*.log
examples/*.toc
examples/*.idx
examples/*.scn

# but keep sources
!examples/*.w

# rasterized previews
*.png

# stray TeX scratch logs, and CWEB cweave aux files (.idx index, .scn section
# names) -- gweave never writes these, but running cweave in-tree drops them
texput.log
*.toc
*.idx
*.scn

# VS Code extension package
*.vsix
