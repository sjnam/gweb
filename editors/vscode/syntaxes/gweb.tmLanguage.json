{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GWEB",
  "scopeName": "source.gweb",
  "injections": {
    "L:meta.embedded.block.go": {
      "comment": "Inside a code part, source.go pushes its own nested rules (a brace block, a function body) whose scope escapes this grammar's code-section end. Within those nested scopes the in-code control codes (a @<name@> reference whose name holds an apostrophe, in particular) would otherwise be scanned as Go, and the apostrophe would open a rune literal that never closes -- turning the rest of the file into a string. Re-inject the control codes and a line-bounded reading of Go's quote literals (which never span physical lines) so no stray quote can run past its own line.",
      "patterns": [
        { "include": "#in-code-codes" },
        { "include": "#go-quote-bounded" }
      ]
    }
  },
  "patterns": [
    { "include": "#change-control" },
    { "include": "#code-section" },
    { "include": "#section-opener" },
    { "include": "#directives" },
    { "include": "#include-line" },
    { "include": "#control-text" },
    { "include": "#section-ref" },
    { "include": "#at-escape" },
    { "include": "#at-punct" },
    { "include": "#inline-code" },
    { "include": "#tex" }
  ],
  "repository": {
    "change-control": {
      "comment": "@x / @y / @z lines of a change file (leading whitespace allowed)",
      "match": "^[ \\t]*@[xyz][ \\t]*$",
      "name": "keyword.control.change.gweb"
    },
    "section-opener": {
      "patterns": [
        {
          "comment": "@* , @** , @*N : starred (chapter) section",
          "match": "^[ \\t]*(@\\*+[0-9]*)",
          "captures": { "1": { "name": "keyword.control.section.star.gweb" } }
        },
        {
          "comment": "@<space>, @<tab>, @ at end of line : ordinary section",
          "match": "^[ \\t]*(@)(?=[ \\t]|$)",
          "captures": { "1": { "name": "keyword.control.section.gweb" } }
        }
      ]
    },
    "code-section": {
      "comment": "A code part: @c / @p, or @<name@>= , or @(file@>= , optionally after an inline section opener (@ @<name@>=). Leading whitespace is allowed, mirroring the tangler. Embeds Go until the next section opener.",
      "begin": "^[ \\t]*(@[cp])(?=[ \\t]|$)|^[ \\t]*(@<(?:[^@]|@@)*?@>)[ \\t]*(=)|^[ \\t]*(@\\((?:[^@]|@@)*?@>)[ \\t]*(=)|^[ \\t]*@[ \\t]+(@<(?:[^@]|@@)*?@>)[ \\t]*(=)|^[ \\t]*@[ \\t]+(@\\((?:[^@]|@@)*?@>)[ \\t]*(=)",
      "beginCaptures": {
        "1": { "name": "keyword.control.codestart.gweb" },
        "2": { "name": "entity.name.section.gweb" },
        "3": { "name": "keyword.operator.gweb" },
        "4": { "name": "entity.name.section.file.gweb" },
        "5": { "name": "keyword.operator.gweb" },
        "6": { "name": "entity.name.section.gweb" },
        "7": { "name": "keyword.operator.gweb" },
        "8": { "name": "entity.name.section.file.gweb" },
        "9": { "name": "keyword.operator.gweb" }
      },
      "end": "(?=^[ \\t]*@\\*)|(?=^[ \\t]*@(?:[ \\t]|$))",
      "contentName": "meta.embedded.block.go",
      "patterns": [
        { "include": "#in-code-codes" },
        { "include": "source.go" }
      ]
    },
    "directives": {
      "comment": "@d / @f / @s formatting directives",
      "match": "^[ \\t]*(@[dfs])(?=[ \\t])",
      "captures": { "1": { "name": "keyword.control.directive.gweb" } }
    },
    "include-line": {
      "comment": "@i include",
      "match": "^[ \\t]*(@i)([ \\t]+)(.*)$",
      "captures": {
        "1": { "name": "keyword.control.import.gweb" },
        "3": { "name": "string.unquoted.include.gweb" }
      }
    },
    "control-text": {
      "comment": "Argument-terminated control codes @^ @. @: (index), @= (verbatim), @t (TeX), @q (ignored)",
      "patterns": [
        {
          "begin": "@\\^",
          "end": "@>",
          "name": "meta.index.roman.gweb",
          "beginCaptures": { "0": { "name": "keyword.control.index.gweb" } },
          "endCaptures": { "0": { "name": "keyword.control.index.gweb" } }
        },
        {
          "begin": "@\\.",
          "end": "@>",
          "name": "meta.index.typewriter.gweb",
          "beginCaptures": { "0": { "name": "keyword.control.index.gweb" } },
          "endCaptures": { "0": { "name": "keyword.control.index.gweb" } }
        },
        {
          "begin": "@:",
          "end": "@>",
          "name": "meta.index.custom.gweb",
          "beginCaptures": { "0": { "name": "keyword.control.index.gweb" } },
          "endCaptures": { "0": { "name": "keyword.control.index.gweb" } }
        },
        {
          "begin": "@=",
          "end": "@>",
          "name": "string.other.verbatim.gweb",
          "beginCaptures": { "0": { "name": "keyword.control.gweb" } },
          "endCaptures": { "0": { "name": "keyword.control.gweb" } }
        },
        {
          "begin": "@t",
          "end": "@>",
          "name": "meta.tex.inserted.gweb",
          "beginCaptures": { "0": { "name": "keyword.control.gweb" } },
          "endCaptures": { "0": { "name": "keyword.control.gweb" } }
        },
        {
          "begin": "@q",
          "end": "@>",
          "name": "comment.block.gweb",
          "beginCaptures": { "0": { "name": "keyword.control.gweb" } },
          "endCaptures": { "0": { "name": "keyword.control.gweb" } }
        }
      ]
    },
    "section-ref": {
      "comment": "@<name@> reference to a named section",
      "match": "@<(?:[^@]|@@)*?@>",
      "name": "entity.name.section.gweb"
    },
    "at-escape": {
      "comment": "@@ literal at-sign, and @% line comment",
      "patterns": [
        { "match": "@@", "name": "constant.character.escape.gweb" },
        { "match": "@%.*$", "name": "comment.line.at-percent.gweb" }
      ]
    },
    "at-punct": {
      "comment": "single-character control codes: @& @, @/ @| @# @! @+ @[ @] @;",
      "match": "@[&,/|#!+;\\[\\]]",
      "name": "keyword.operator.control.gweb"
    },
    "in-code-codes": {
      "patterns": [
        { "include": "#control-text" },
        { "include": "#section-ref" },
        { "include": "#at-escape" },
        { "include": "#at-punct" }
      ]
    },
    "go-quote-bounded": {
      "comment": "Go's interpreted-string and rune literals, read one physical line at a time (they never span lines in real Go). Each is matched whole when it closes on the line; a lone quote is swallowed as a single harmless character. This keeps source.go's own unbounded string/rune rules -- which would run to the next matching quote anywhere, even pages away -- from firing on a stray quote. Raw strings (backticks) may legitimately span lines and are left to source.go.",
      "patterns": [
        { "match": "'(?:\\\\.|[^'\\\\])*'", "name": "string.quoted.rune.go" },
        { "match": "'", "name": "string.quoted.rune.go" },
        { "match": "\"(?:\\\\.|[^\"\\\\])*\"", "name": "string.quoted.double.go" },
        { "match": "\"", "name": "string.quoted.double.go" }
      ]
    },
    "inline-go": {
      "comment": "A flat, self-contained reading of Go for |...| inline spans. Unlike source.go it never pushes a multi-line block, so the closing | is always reachable even when the span shows a dangling brace such as |func f() {|. | is deliberately absent from the operator class so it can never be mistaken for the span's own closing bar.",
      "patterns": [
        { "include": "#in-code-codes" },
        { "match": "//.*$", "name": "comment.line.double-slash.go" },
        { "match": "`[^`]*`", "name": "string.quoted.raw.go" },
        { "include": "#go-quote-bounded" },
        { "match": "\\b(break|case|chan|const|continue|default|defer|else|fallthrough|for|func|go|goto|if|import|interface|map|package|range|return|select|struct|switch|type|var)\\b", "name": "keyword.control.go" },
        { "match": "\\b(bool|byte|complex64|complex128|error|float32|float64|int|int8|int16|int32|int64|rune|string|uint|uint8|uint16|uint32|uint64|uintptr|any)\\b", "name": "storage.type.go" },
        { "match": "\\b(true|false|iota|nil)\\b", "name": "constant.language.go" },
        { "match": "\\b(append|cap|close|complex|copy|delete|imag|len|make|new|panic|print|println|real|recover)\\b", "name": "support.function.builtin.go" },
        { "match": "\\b\\d[\\d_]*(\\.[\\d_]*)?([eE][-+]?\\d+)?\\b|\\b0[xX][0-9a-fA-F_]+\\b", "name": "constant.numeric.go" },
        { "match": "[a-zA-Z_\\p{L}][\\w\\p{L}]*(?=\\s*\\()", "name": "entity.name.function.go" },
        { "match": "[a-zA-Z_\\p{L}][\\w\\p{L}]*", "name": "variable.other.go" },
        { "match": "[-+*/%<>=!&^~:.]+", "name": "keyword.operator.go" },
        { "match": "[{}()\\[\\]]", "name": "punctuation.definition.bracket.go" }
      ]
    },
    "inline-code": {
      "comment": "|...| inline Go code inside TeX commentary; \\| is a literal bar",
      "begin": "(?<!\\\\)\\|",
      "end": "(?<!\\\\)\\|",
      "beginCaptures": { "0": { "name": "punctuation.definition.code.gweb" } },
      "endCaptures": { "0": { "name": "punctuation.definition.code.gweb" } },
      "contentName": "meta.embedded.inline.go",
      "patterns": [{ "include": "#inline-go" }]
    },
    "tex": {
      "comment": "Light TeX highlighting for the commentary/limbo",
      "patterns": [
        { "match": "(?<!\\\\)%.*$", "name": "comment.line.percentage.tex" },
        { "match": "\\\\[a-zA-Z@]+", "name": "support.function.general.tex" },
        { "match": "\\\\.", "name": "constant.character.escape.tex" },
        {
          "begin": "(?<!\\\\)\\$\\$",
          "end": "\\$\\$",
          "name": "markup.math.display.tex"
        },
        {
          "begin": "(?<!\\\\)\\$",
          "end": "(?<!\\\\)\\$",
          "name": "markup.math.inline.tex"
        },
        { "match": "[{}]", "name": "punctuation.definition.group.tex" }
      ]
    }
  }
}
